    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI (app.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                // Uncomment to run with uvicorn for FastAPI
                // "-m", "uvicorn", "app:app", "--reload", "--host", "0.0.0.0", "--port", "8001"
            ]
        }
    ]
}
